{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FrontPress Local",
  "version": "0.2.0",
  "identifier": "com.markokrstic.frontpress-local",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FrontPress Local",
        "width": 980,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/krstivoja/frontpress-local/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBMjYzREY0N0ZBNEZCNgpSV1MyVC9wSDMyT2lBNkl3ci9kQ2VXUVQxM0tVSkNzZzIzMlZVemlMRFI2c2l1bFNDN2FjN0JLdQo="
    }
  }
}
